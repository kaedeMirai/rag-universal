RAG_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rag_system

RAG_BOOTSTRAP_ADMIN_USERNAME=admin
RAG_BOOTSTRAP_ADMIN_PASSWORD=admin12345
RAG_BOOTSTRAP_ADMIN_FIRST_NAME=System
RAG_BOOTSTRAP_ADMIN_LAST_NAME=Admin
RAG_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

RAG_BACKEND_URL=http://127.0.0.1:8006
RAG_CHAT_REQUEST_TIMEOUT_SECONDS=300
RAG_SESSION_TTL_DAYS=7

RAG_EMBEDDING_PROVIDER=huggingface
RAG_GENERATION_PROVIDER=huggingface
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_GENERATION_MODEL=Qwen/Qwen2.5-7B-Instruct
RAG_GENERATION_DTYPE=auto
RAG_GENERATION_DEVICE_MAP=auto
RAG_EVAL_DATASET_PATH=

RAG_VECTOR_INDEX_PATH=scripts/vector.index
RAG_METADATA_PATH=scripts/meta_data.json
RAG_SOURCE_CSV_PATH=scripts/temp.csv

RAG_DENSE_TOP_K=24
RAG_BM25_TOP_K=24
RAG_FINAL_TOP_K=6
RAG_DOC_LOOKUP_FINAL_TOP_K=4
RAG_MAX_CONTEXT_TOKENS=512
RAG_MAX_CHUNKS_PER_DOCUMENT=2
RAG_DOC_LOOKUP_MAX_CHUNKS_PER_DOCUMENT=3

RAG_BM25_TITLE_WEIGHT=8.0
RAG_BM25_PATH_WEIGHT=3.0
RAG_BM25_TEXT_WEIGHT=1.0

RAG_RERANK_DENSE_WEIGHT=0.45
RAG_RERANK_BM25_WEIGHT=0.30
RAG_RERANK_TITLE_WEIGHT=0.15
RAG_RERANK_PATH_WEIGHT=0.05
RAG_RERANK_COVERAGE_WEIGHT=0.05

RAG_DOC_LOOKUP_EXACT_BOOST=0.25
RAG_DOC_LOOKUP_TITLE_BOOST=0.18
RAG_DOC_LOOKUP_PATH_BOOST=0.10

RAG_GPU_CONTEXT_BUDGETS=512,384,256
RAG_GPU_MAX_NEW_TOKENS=128,96,64
RAG_CPU_CONTEXT_BUDGETS=1200,900
RAG_CPU_MAX_NEW_TOKENS=220,128

RAG_GENERATION_TEMPERATURE=0.2
RAG_GENERATION_TOP_P=0.9
RAG_GENERATION_DO_SAMPLE=true
RAG_PROFILE=balanced
RAG_PRELOAD_MODELS_ON_STARTUP=false

RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=100
RAG_EMBEDDING_BATCH_SIZE=8
RAG_EMBEDDING_DEVICE=cuda

RAG_DOCUMENT_LOOKUP_PATTERN=(№|no|служебн\\w*\\s+задан\\w*|приказ|положение|регламент|инструкц\\w*|документ)
RAG_REFERENCE_STOPWORDS=мне,бы,почитать,покажи,показать,найди,нужен,нужно,документ,документа,документе,положение,приказ,регламент,инструкция,из,про,по,могу,я,хочу

RAG_SYSTEM_PROMPT=Ты корпоративный ассистент. Отвечай только по предоставленному контексту. Если контекста недостаточно, прямо скажи об этом. Не выдумывай детали.
RAG_DOCUMENT_LOOKUP_PROMPT_SUFFIX=Если пользователь ищет конкретный документ, сначала назови наиболее вероятный документ и кратко перескажи, что удалось извлечь из найденных фрагментов.

PYTORCH_ALLOC_CONF=expandable_segments:True
